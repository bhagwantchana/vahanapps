# ============================================================
#  fleet_monitor (Flutter customer app) — .gitignore
# ============================================================

# ----- Flutter / Dart build output --------------------------
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.metadata
*.g.dart
*.freezed.dart

# ----- Android build & credentials -------------------------
android/.gradle/
android/local.properties

# !!! KEYSTORE — NEVER COMMIT !!!
android/app/*.jks
android/app/*.keystore
android/key.properties

# Firebase (add to server env / CI secret instead)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# ----- iOS build artifacts ----------------------------------
ios/Pods/
ios/.symlinks/
ios/Flutter/ephemeral/
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh

# ----- macOS build artifacts --------------------------------
macos/Pods/
macos/.symlinks/
macos/Flutter/ephemeral/

# ----- Linux / Windows / Web build artifacts ----------------
linux/flutter/ephemeral/
windows/flutter/ephemeral/

# ----- Build helper scripts (local only) --------------------
build_release_apk.bat
build_release_apk.ps1

# ----- Generated analysis reports ---------------------------
analysis_report.txt
analysis_report_utf8.txt

# ----- Release ZIPs (distribute via Drive/Play) -------------
*.zip

# ----- IDE / OS noise ---------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.idea/
*.iml
*.sublime-workspace
